@model edocs.Models.Category


@{
    ViewBag.Title = "استعراض بيانات صنف";
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

@section addcss{
    <link href="@Url.Content("~/content/simple-crud.css")" rel="stylesheet" type="text/css" />
}

@section addtolbar{
    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Category")">الاصناف</a></li>
    <li class="breadcrumb-item active">تفاصيل الصنف</li>
}


<section class="records-module">
    <div class="records-heading">
        <div>
            <span class="records-eyebrow">
                <i class="fa fa-eye"></i>
                تفاصيل
            </span>
            <h2>تفاصيل الصلاحية</h2>
            <p>عرض بيانات الصلاحية المحددة.</p>
        </div>
    </div>

    <div class="records-card">
        <div class="records-card-header">
            <div>
                <h3>معلومات الصلاحية</h3>
            </div>
        </div>

        <div class="records-card-body">
            <dl class="details-list">
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.NAME)</dt>
                    <dd>
                        <span class="record-name-badge">
                            @Html.DisplayFor(model => model.NAME)
                        </span>
                    </dd>
                </div>
            </dl>
            <dl class="details-list">
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.DESCR)</dt>
                    <dd>
                        <span class="record-name-badge">
                            @Html.DisplayFor(model => model.DESCR)
                        </span>
                    </dd>
                </div>
            </dl>
            <dl class="details-list">
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.PARENT_NAME)</dt>
                    <dd>
                        <span class="record-name-badge">
                            @Html.DisplayFor(model => model.ParentCategory.NAME)
                        </span>
                    </dd>
                </div>
            </dl>
            <dl class="details-list">
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.FOLDER_NAME)</dt>
                    <dd>
                        <span class="record-name-badge">
                            @Html.DisplayFor(model => model.FOLDER_NAME)
                        </span>
                    </dd>
                </div>
            </dl>

            <div class="records-actions">
                <a href="@Url.Action("Edit", "Category", new { id = Model.ID })" class="btn-app-primary">
                    <i class="fa fa-pencil"></i>
                    تعديل
                </a>

                <a href="@Url.Action("Index", "Category")" class="btn-app-secondary">
                    <i class="fa fa-arrow-right"></i>
                    العودة للقائمة
                </a>
            </div>
        </div>
    </div>
</section>
