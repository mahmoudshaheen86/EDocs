@model edocs.Models.DocAttribute

@{
    ViewBag.Title = "حذف واصفة";
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

@section addcss{
    <link href="@Url.Content("~/content/simple-crud.css")" rel="stylesheet" type="text/css" />
}

@section addtolbar{
    <li class="breadcrumb-item"><a href="@Url.Action("Index", "DocAttribute")">الواصفات</a></li>
    <li class="breadcrumb-item active">حذف واصفة</li>
}

<section class="records-module">
    <div class="records-heading">
        <div>
            <span class="records-eyebrow">
                <i class="fa fa-trash"></i>
                حذف
            </span>
            <h2>حذف واصفة</h2>
            <p>تأكد من أن الواصفة غير مستخدمة بطريقة تؤثر على بيانات الوثائق قبل تنفيذ الحذف.</p>
        </div>
    </div>

    <div class="delete-warning">
        <i class="fa fa-exclamation-triangle"></i>
        هل أنت متأكد من أنك تريد حذف الواصفة؟
    </div>

    <div class="records-card">
        <div class="records-card-header">
            <div>
                <h3>تأكيد الحذف</h3>
                <span>هذه العملية قد لا يمكن التراجع عنها.</span>
            </div>
        </div>

        <div class="records-card-body">
            @Html.ValidationSummary(true, "", new { @class = "validation-summary" })
            <dl class="details-list">
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.NAME)</dt>
                    <dd>@Html.DisplayFor(model => model.NAME)</dd>
                </div>

                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.Category)</dt>
                    <dd>
                        <span class="record-name-badge">
                            <i class="fa fa-folder"></i>
                            @(Model.CategoryFk != null ? Model.CategoryFk.NAME : "")
                        </span>
                    </dd>
                </div>

                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.TYPE)</dt>
                    <dd>
                        <span class="user-type-badge">
                            <i class="fa fa-sliders"></i>
                            @Html.DisplayFor(model => model.TYPE)
                        </span>
                    </dd>
                </div>

                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.COLM_ORDER)</dt>
                    <dd>@Html.DisplayFor(model => model.COLM_ORDER)</dd>
                </div>
            </dl>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="records-actions">
                    <button type="submit" class="btn-app-danger">
                        <i class="fa fa-trash"></i>
                        تأكيد الحذف
                    </button>

                    <a href="@Url.Action("Index", "DocAttribute", new { id = Model.Category })" class="btn-app-secondary">
                        <i class="fa fa-arrow-right"></i>
                        إلغاء والعودة
                    </a>
                </div>
            }
        </div>
    </div>
</section>
