@model edocs.Models.DocAttribute

@{
    ViewBag.Title = "تعديل بيانات واصفة";
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

@section addcss{
    <link href="@Url.Content("~/content/simple-crud.css")" rel="stylesheet" type="text/css" />
}

@section addtolbar{
    <li class="breadcrumb-item"><a href="@Url.Action("Index", "DocAttribute")">الواصفات</a></li>
    <li class="breadcrumb-item active">تعديل بيانات واصفة</li>
}

<section class="records-module">
    <div class="records-heading">
        <div>
            <span class="records-eyebrow">
                <i class="fa fa-pencil"></i>
                تعديل
            </span>
            <h2>تعديل بيانات واصفة</h2>
            <p>قم بتحديث بيانات الواصفة ونمطها وترتيبها ضمن التصنيف.</p>
        </div>
    </div>

    <div class="records-card">
        <div class="records-card-header">
            <div>
                <h3>بيانات الواصفة</h3>
                <span>تحديث بيانات الحقل المحدد.</span>
            </div>
        </div>

        <div class="records-card-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "records-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary" })
                @Html.HiddenFor(model => model.ID)

                <div class="form-group">
                    @Html.LabelFor(model => model.NAME)
                    @Html.EditorFor(model => model.NAME, new { htmlAttributes = new { @class = "form-control", placeholder = "اسم الواصفة" } })
                    @Html.ValidationMessageFor(model => model.NAME, "", new { @class = "field-validation-error" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.TYPE, "نمط الواصفة")
                    @Html.DropDownList("TYPE", null, "اختر نمط الواصفة", new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.TYPE, "", new { @class = "field-validation-error" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Category, "التصنيف")
                    @Html.DropDownList("Category", null, "اختر التصنيف", new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Category, "", new { @class = "field-validation-error" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.COLM_ORDER)
                    @Html.EditorFor(model => model.COLM_ORDER, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", step = "1", placeholder = "ترتيب العمود" } })
                    @Html.ValidationMessageFor(model => model.COLM_ORDER, "", new { @class = "field-validation-error" })
                </div>

                <div class="records-actions">
                    <button type="submit" class="btn-app-primary">
                        <i class="fa fa-save"></i>
                        حفظ التعديلات
                    </button>

                    <a href="@Url.Action("Index", "DocAttribute", new { id = Model.Category })" class="btn-app-secondary">
                        <i class="fa fa-arrow-right"></i>
                        العودة للواصفات
                    </a>
                </div>
            }
        </div>
    </div>
</section>
