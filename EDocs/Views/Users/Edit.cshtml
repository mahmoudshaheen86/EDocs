@model edocs.Models.UserFormViewModel

@{
    ViewBag.Title = "تعديل بيانات مستخدم";
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

@section addcss{
    <link href="@Url.Content("~/content/simple-crud.css")" rel="stylesheet" type="text/css" />
}

@section addtolbar{
    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Users")">المستخدمون</a></li>
    <li class="breadcrumb-item active">تعديل بيانات مستخدم</li>
}

<section class="records-module">
    <div class="records-heading">
        <div>
            <span class="records-eyebrow">
                <i class="fa fa-pencil"></i>
                تعديل
            </span>
            <h2>تعديل بيانات مستخدم</h2>
            <p>قم بتحديث بيانات المستخدم أو تغيير الصلاحية وكلمة المرور عند الحاجة.</p>
        </div>
    </div>

    <div class="records-card">
        <div class="records-card-header">
            <div>
                <h3>بيانات المستخدم</h3>
                <span>تحديث بيانات الحساب المحدد.</span>
            </div>
        </div>

        <div class="records-card-body">
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "records-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "validation-summary" })
                @Html.HiddenFor(model => model.Id)

<div class="records-form-grid">
    <div class="form-field">
        @Html.LabelFor(model => model.UserName)
        <div class="input-with-icon">
            <i class="fa fa-user"></i>
            @Html.TextBoxFor(model => model.UserName, new { @class = "form-control", placeholder = "اسم المستخدم" })
        </div>
        @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "field-validation-error" })
    </div>

    <div class="form-field">
        @Html.LabelFor(model => model.FULLNAME)
        <div class="input-with-icon">
            <i class="fa fa-id-card"></i>
            @Html.TextBoxFor(model => model.FULLNAME, new { @class = "form-control", placeholder = "الاسم الكامل" })
        </div>
        @Html.ValidationMessageFor(model => model.FULLNAME, "", new { @class = "field-validation-error" })
    </div>

    <div class="form-field">
        @Html.LabelFor(model => model.Email)
        <div class="input-with-icon">
            <i class="fa fa-envelope"></i>
            @Html.TextBoxFor(model => model.Email, new { @class = "form-control", placeholder = "email@example.com" })
        </div>
        @Html.ValidationMessageFor(model => model.Email, "", new { @class = "field-validation-error" })
    </div>

    <div class="form-field">
        @Html.LabelFor(model => model.PhoneNumber)
        <div class="input-with-icon">
            <i class="fa fa-phone"></i>
            @Html.TextBoxFor(model => model.PhoneNumber, new { @class = "form-control", placeholder = "رقم الهاتف" })
        </div>
        @Html.ValidationMessageFor(model => model.PhoneNumber, "", new { @class = "field-validation-error" })
    </div>

    <div class="form-field">
        @Html.LabelFor(model => model.USERTYPE)
        <div class="input-with-icon">
            <i class="fa fa-id-badge"></i>
            @Html.DropDownListFor(model => model.USERTYPE, ViewBag.UserTypes as IEnumerable<SelectListItem>, "اختر نوع المستخدم", new { @class = "form-control" })
        </div>
        @Html.ValidationMessageFor(model => model.USERTYPE, "", new { @class = "field-validation-error" })
    </div>

    <div class="form-field">
        @Html.LabelFor(model => model.RoleName)
        <div class="input-with-icon">
            <i class="fa fa-shield"></i>
            @Html.DropDownListFor(model => model.RoleName, ViewBag.RolesList as IEnumerable<SelectListItem>, "اختر الصلاحية", new { @class = "form-control" })
        </div>
        @Html.ValidationMessageFor(model => model.RoleName, "", new { @class = "field-validation-error" })
    </div>

    <div class="form-field">
        @Html.LabelFor(model => model.Password)
        <div class="input-with-icon">
            <i class="fa fa-lock"></i>
            @Html.PasswordFor(model => model.Password, new { @class = "form-control", placeholder = "كلمة المرور" })
        </div>
        @Html.ValidationMessageFor(model => model.Password, "", new { @class = "field-validation-error" })
    </div>

    <div class="form-field">
        @Html.LabelFor(model => model.ConfirmPassword)
        <div class="input-with-icon">
            <i class="fa fa-lock"></i>
            @Html.PasswordFor(model => model.ConfirmPassword, new { @class = "form-control", placeholder = "تأكيد كلمة المرور" })
        </div>
        @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "field-validation-error" })
    </div>
</div>
<div class="form-help">
    اترك كلمة المرور وتأكيدها فارغين إذا كنت لا تريد تغيير كلمة المرور الحالية.
</div>


                <div class="records-actions" style="margin-top:22px;">
                    <button type="submit" class="btn-app-primary">
                        <i class="fa fa-save"></i>
                        حفظ التعديلات
                    </button>

                    <a href="@Url.Action("Index", "Users")" class="btn-app-secondary">
                        <i class="fa fa-arrow-right"></i>
                        العودة للقائمة
                    </a>
                </div>
            }
        </div>
    </div>
</section>
