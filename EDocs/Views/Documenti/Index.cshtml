@model edocs.ViewModels.DocumentIndexViewModel

@{
    edocs.Models.Category catInfo = Model.Category;
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

@section addcss{
    <link href="@Url.Content("~/content/datatables/rwd-table.min.css")" rel="stylesheet" type="text/css" media="screen" />
    <link href="@Url.Content("~/content/datatables/jquery.dataTables.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/content/buttons.dataTables.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/content/magnific-popup/magnific-popup.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/content/jquery-ui.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/content/datatables/app-datatables.css")" rel="stylesheet" type="text/css" />
}

@section addtolbar{
    @{
        var parent = catInfo != null ? catInfo.ParentCategory : null;
        var grandParent = parent != null ? parent.ParentCategory : null;

        if (grandParent != null && grandParent.PARENT_NAME != 0)
        {
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Document", new { categoryID = grandParent.ID })">@grandParent.NAME</a>
            </li>
        }

        if (parent != null && parent.PARENT_NAME != 0)
        {
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Document", new { categoryID = parent.ID })">@parent.NAME</a>
            </li>
        }
    }

    <li class="breadcrumb-item active">@ViewBag.Title</li>
}

<section class="table-module">
    <div class="module-heading">
        <div>
            <span class="module-eyebrow">
                <i class="fa fa-folder-open"></i>
                الوثائق
            </span>

            <h2>
                <a href="@Url.Action("Index", "Document", new { categoryID = Request.Params["categoryID"] })">
                    @ViewBag.Title
                </a>
            </h2>

            <p>
                يمكنك استعراض الوثائق، البحث داخل الحقول، تصدير النتائج، وإدارة المرفقات والعمليات المرتبطة بكل وثيقة.
            </p>
        </div>

        <div class="module-actions">
            @if (catInfo != null && (catInfo.Children == null || !catInfo.Children.Any()) && Model.UserRole == "manager")
            {
                <a class="btn-app-primary" href="@Url.Action("Create", "Document", new { categoryID = Request.Params["categoryID"] })">
                    <i class="fa fa-plus"></i>
                    إضافة وثيقة جديدة
                </a>
            }
        </div>
    </div>

    @if (Model.StatusMessage != null)
    {
        <div class="status-message-wrapper">
            @Html.Raw(Model.StatusMessage)
        </div>
    }

    <div class="data-card">
        <div class="data-card-header">
            <div>
                <h3>@ViewBag.Title</h3>
                <span>قائمة الوثائق الخاصة بالصنف المحدد</span>
            </div>

            <div class="data-card-tools">
                <span class="tool-hint">
                    <i class="fa fa-info-circle"></i>
                    استخدم حقول البحث أسفل عناوين الأعمدة للتصفية الدقيقة.
                </span>
            </div>
        </div>

        <div class="table-responsive app-table-responsive">
            <table id="datatable" class="table app-data-table table-hover">
                <thead>
                    @if (ViewBag.mode != "Empty")
                    {
                        <tr>
                            <th data-priority="1">رقم الوثيقة</th>
                            <th data-priority="1">تاريخ الوثيقة</th>

                            @if (Request.Params["categoryID"] != null)
                            {
                                List<edocs.Models.DocAttribute> attrs = Model.Attributes.ToList();

                                foreach (var docAtt in attrs)
                                {
                                    <th data-priority="1">@docAtt.NAME</th>
                                }
                            }

                            <th data-priority="1" class="actions-column no-filter">المرفقات</th>
                            <th data-priority="1" class="actions-column no-filter">العمليات</th>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <th>النتيجة</th>
                        </tr>
                    }
                </thead>

                <tbody>
                    @if (ViewBag.mode == "Empty")
                    {
                        <tr>
                            <td class="empty-table-message">لم يتم العثور على أي وثائق ضمن هذا الصنف.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@section addjs{
    <script src="@Url.Content("~/content/datatables/jquery.dataTables.min.js")"></script>
    <script src="@Url.Content("~/content/datatables/dataTables.bootstrap.js")"></script>
    <script src="@Url.Content("~/scripts/rwd-table.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/content/magnific-popup/magnific-popup.js")"></script>
    <script src="@Url.Content("~/scripts/jquery-ui.min.js")" type="text/javascript"></script>

    <script src="@Url.Content("~/scripts/dataTables.buttons.min.js")" type="text/javascript" charset="utf-8"></script>
    <script src="@Url.Content("~/scripts/jszip.min.js")" type="text/javascript" charset="utf-8"></script>
    <script src="@Url.Content("~/scripts/pdfmake.min.js")" type="text/javascript" charset="utf-8"></script>
    <script src="@Url.Content("~/scripts/vfs_fonts.js")" type="text/javascript" charset="utf-8"></script>
    <script src="@Url.Content("~/scripts/buttons.html5.min.js")" type="text/javascript" charset="utf-8"></script>
    <script src="@Url.Content("~/scripts/buttons.print.min.js")" type="text/javascript" charset="utf-8"></script>
    <script src="@Url.Content("~/content/mark.js")" type="text/javascript" charset="utf-8"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            var isEmptyMode = '@ViewBag.mode' === 'Empty';

            if (isEmptyMode) {
                return;
            }

            $('#datatable thead th').each(function () {
                var $th = $(this);

                if ($th.hasClass('no-filter')) {
                    $th.append('<div class="column-filter-spacer"></div>');
                    return;
                }

                var title = $.trim($th.clone().children().remove().end().text());

                $th.append(
                    '<div class="column-filter">' +
                    '<i class="fa fa-search"></i>' +
                    '<input class="form-control input-sm column-search" type="search" placeholder="بحث في ' + title + '" />' +
                    '</div>'
                );
            });
            var dtColumns = @Html.Raw(Model.Columns);
            var table = $('#datatable').DataTable({
                processing: true,
                serverSide: true,
                searchDelay: 800,

                responsive: false,
                scrollX: true,
                autoWidth: false,

                ajax: {
                    url: '@Url.Action("GetList", "Documenti", new { catId = catInfo.ID })',
                    type: 'POST',
                    dataType: 'json',
                    dataSrc: function (json) {
                        console.log("RAW RESPONSE:", json);
                        return json.data;
                    },
                    error: function (xhr) {
                        console.log("SERVER ERROR:", xhr.responseText);
                    }
                },

                columns: dtColumns,

                columnDefs: [
                    {
                        targets: -1,
                        width: "220px",
                        className: "actions-column no-filter",
                        orderable: false,
                        searchable: false
                    }
                ],

                dom:
                    '<"dt-top-row"<"dt-length"l><"dt-search"f><"dt-buttons"B>>' +
                    'rt' +
                    '<"dt-bottom-row"<"dt-info"i><"dt-pagination"p>>',

                buttons: [
                    {
                        extend: 'copyHtml5',
                        text: '<i class="fa fa-copy"></i> نسخ',
                        exportOptions: { columns: [0, ':visible'] }
                    },
                    {
                        extend: 'excelHtml5',
                        text: '<i class="fa fa-file-excel-o"></i> Excel',
                        exportOptions: { columns: ':visible' }
                    },
                    {
                        extend: 'pdfHtml5',
                        text: '<i class="fa fa-file-pdf-o"></i> PDF',
                        exportOptions: {
                            columns: ':visible',
                            pagesize: 'A4'
                        }
                    },
                    {
                        extend: 'print',
                        text: '<i class="fa fa-print"></i> طباعة',
                        exportOptions: { columns: [1, ':not(:last-child)'] }
                    }
                ],

                language: {
                    processing: '<span class="dt-loader"></span> جاري تحميل البيانات...',
                    search: '',
                    searchPlaceholder: 'بحث عام...',
                    lengthMenu: 'عرض _MENU_ سجل',
                    info: 'عرض _START_ إلى _END_ من أصل _TOTAL_ سجل',
                    infoEmpty: 'لا توجد سجلات متاحة',
                    infoFiltered: '(تمت التصفية من أصل _MAX_ سجل)',
                    zeroRecords: 'لم يتم العثور على نتائج مطابقة',
                    emptyTable: 'لا توجد بيانات متاحة',
                    paginate: {
                        previous: '<i class="fa fa-angle-right"></i> السابق',
                        next: 'التالي <i class="fa fa-angle-left"></i>'
                    }
                }
            });

            $('#datatable thead').on('click keydown', 'input.column-search', function (e) {
                e.stopPropagation();
            });

            table.columns().every(function () {
                var column = this;

                $('input.column-search', column.header()).on('keyup change clear', function () {
                    if (column.search() !== this.value) {
                        column.search(this.value).draw();
                    }
                });
            });

            $('.image-popup').magnificPopup({
                type: 'image',
                closeOnContentClick: true,
                mainClass: 'mfp-fade',
                gallery: {
                    enabled: true,
                    navigateByImgClick: true,
                    preload: [0, 1]
                }
            });
        });
    </script>
}
