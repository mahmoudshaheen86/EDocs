@model edocs.Models.DocAttributes

@{
    ViewBag.Title = "إضافة وثيقة جديدة";
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

<h2>إضافة وثيقة جديدة</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
   

    <div class="form-horizontal">
        <h4>الوثيقة</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.VALUEOF, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.VALUEOF, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.VALUEOF, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.ATTRIBUTEID, "اسم الواصفة", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("ATTRIBUTEID", null, htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.AttributeFk.NAME, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.DOCUMENTID, "اسم الوثيقة", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("DOCUMENTID", null, htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.DOCFk.NAME, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <button type="submit" value="إضافة" class="btn btn-info btn-lg"> إضافة <span class="glyphicon glyphicon-floppy-disk"></span></button>
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("العودة إلى صفحة الحقول", "Index")
</div>
