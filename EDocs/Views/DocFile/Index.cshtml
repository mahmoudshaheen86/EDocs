@model IEnumerable<edocs.Models.DocFile>


@section addcss{
    <!-- DataTables -->
    <link href="~/content/datatables/rwd-table.min.css" rel="stylesheet" type="text/css" media="screen" />
    <link href="~/content/datatables/jquery.dataTables.min.css" rel="stylesheet" type="text/css" />
}
@{
    ViewBag.Title = "الملفات";
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

<a href="files"><h2>الملفات</h2></a>

@Html.Raw(ViewBag.StatusMessage)


<p>
    @Html.ActionLink("إضافة ملف جديد", "Create")
</p>


<div class="content">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="panel panel-border panel-primary">
                    <div class="panel-heading">
                        <a href="files"><h3 class="panel-title">@ViewBag.Title</h3></a>

                    </div>
                    <div class="panel-body table-rep-plugin">
                        <div class="table-responsive" data-pattern="priority-columns" style="padding-top: 15px;">
                            <table id="datatable" class="table table-striped table-hover table-bordered table-small-font table-striped">
                                <thead>
                                    <tr>

                                        <th>
                                            @Html.DisplayNameFor(model => model.NAME)
                                        </th>
                                        <th data-priority="1">
                                            @Html.DisplayNameFor(model => model.DATEOF)
                                        </th>
                                        <th data-priority="1">
                                            @Html.DisplayNameFor(model => model.STATUS)
                                        </th>

                                        <th data-priority="3">
                                            @Html.DisplayNameFor(model => model.DOCUMENTID)
                                        </th>
                                        <th data-priority="3">
                                            @Html.DisplayNameFor(model => model.USERID)
                                        </th>
                                        <th data-priority="3">
                                            الصورة
                                        </th>
                                        <th data-priority="6">العمليات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>

                                            <td>
                                                @Html.DisplayFor(modelItem => item.NAME)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.DATEOF)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.STATUS)
                                            </td>

                                            <td>
                                                @Html.DisplayFor(modelItem => item.DOCFk.NAME)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.USERFk.UserName)
                                            </td>
                                            <td>
                                                <a href="~/uploads/@Html.DisplayFor(modelItem => item.NAME)" class="image-popup" title="@Html.DisplayFor(modelItem => item.NAME)">
                                                    <img src="~/uploads/@Html.DisplayFor(modelItem => item.NAME)" class="thumbnail" style="width:48px;height:48px;" />
                                                </a>
                                            </td>
                                            <td>
                                                @Html.ActionLink("تعديل", "Edit", new { id = item.ID }) |

                                                @Html.ActionLink("استعراض", "Details", new { id = item.ID }) |
                                                @Html.ActionLink("حذف", "Delete", new { id = item.ID })
                                            </td>


                                        </tr>
                                    }
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div> <!-- End Row -->

@section addjs{
    <script src="~/content/datatables/jquery.dataTables.min.js"></script>
    <script src="~/content/datatables/dataTables.bootstrap.js"></script>
    <script src="~/scripts/rwd-table.min.js" type="text/javascript"></script>


    <script type="text/javascript">
        $(document).ready(function () {
            $('#datatable').DataTable({

                language: {

                    paginate: {
                        previous: ' <i class="glyphicon glyphicon-arrow-right"></i> قبل  ',
                        next: 'بعد <i class="glyphicon glyphicon-arrow-left">'

                    }
                }
            });

            $('div.dataTables_filter input').attr('placeholder', 'بحث ...');
            $('div.dataTables_filter').append('<span class="glyphicon glyphicon-search"></span>');
            //  $('div.dataTables_filter').append('<span ><button class="btn btn-info" type="button"> <i class="glyphicon glyphicon-search"></i> </button> </span>');
        });


    </script>
}