@model edocs.Models.UserCategory

@{
    ViewBag.Title = "حذف صلاحية";
    Layout = "~/Views/shared/_MainLayout.cshtml";
}

@section addcss{
    <link href="@Url.Content("~/content/simple-crud.css")" rel="stylesheet" type="text/css" />
}

@section addtolbar{
    <li class="breadcrumb-item"><a href="@Url.Action("Index", "UserCategory")">الاصناف</a></li>
    <li class="breadcrumb-item active">حذف صلاحية</li>
}


<section class="records-module">
    <div class="records-heading">
        <div>
            <span class="records-eyebrow">
                <i class="fa fa-trash"></i>
                حذف صلاحية
            </span>
        </div>
    </div>

    <div class="records-card">
        <div class="records-card-header">
            <div>
                <h3>تأكيد الحذف</h3>
                <span>هذه العملية قد لا يمكن التراجع عنها.</span>
            </div>
        </div>

        <div class="records-card-body">
            <div class="delete-warning">
                <i class="fa fa-exclamation-triangle"></i>
                هل أنت متأكد أنك تريد حذف هذا الصنف؟
            </div>

            <dl class="details-list">
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.CategoryFK.NAME)</dt>
                    <dd>
                        <span class="record-name-badge">
                            <i class="fa fa-address-card"></i>
                            @Html.DisplayFor(model => model.CategoryFK.NAME)
                        </span>
                    </dd>
                </div>
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.UserFK.UserName)</dt>
                    <dd>
                        <span class="record-name-badge">
                            <i class="fa fa-level-up"></i>
                            @Html.DisplayFor(model => model.UserFK.UserName)
                        </span>
                    </dd>
                </div>
                <div class="details-row">
                    <dt>@Html.DisplayNameFor(model => model.TYPE)</dt>
                    <dd>
                        <span class="record-name-badge">
                            <i class="fa fa-level-up"></i>
                            @Html.DisplayFor(model => model.TYPE)
                        </span>
                    </dd>
                </div>
            </dl>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="records-actions">
                    <button type="submit" class="btn-app-danger">
                        <i class="fa fa-trash"></i>
                        تأكيد الحذف
                    </button>

                    <a href="@Url.Action("Index", "UserCategory")" class="btn-app-secondary">
                        <i class="fa fa-arrow-right"></i>
                        إلغاء والعودة
                    </a>
                </div>
            }
        </div>
    </div>
</section>